{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "iOS Simulator",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "/bin/zsh",
      "args": [
        "${workspaceFolder}/.vscode/run-ios.sh",
        "simulator"
      ],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "outputCapture": "std"
    },
    {
      "name": "Connected iPhone",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "/bin/zsh",
      "args": [
        "${workspaceFolder}/.vscode/run-ios.sh",
        "device"
      ],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "outputCapture": "std"
    },
    {
      "name": "macOS Daemon",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "/bin/zsh",
      "args": [
        "${workspaceFolder}/.vscode/run-daemon.sh"
      ],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "outputCapture": "std"
    }
  ],
  "compounds": [
    {
      "name": "Daemon + Simulator",
      "configurations": ["macOS Daemon", "iOS Simulator"]
    },
    {
      "name": "Daemon + iPhone",
      "configurations": ["macOS Daemon", "Connected iPhone"]
    }
  ]
}
